{
  "manifest_version": 3,
  "name": "Sticky Notes",
  "description": "Sticky notes in Chrome's side panel + Stand Reminder — your productivity companion.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Sticky Notes",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "activeTab",
    "idle",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
